{
  "name": "korgkode-sidecar",
  "displayName": "KorgKode Autonomy",
  "description": "IDE sidecar for the KorgKode AI Swarm — refactor, heal, and profile directly from VS Code.",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Machine Learning",
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "korgkode.refactorFile",
        "title": "KorgKode: Refactor Current File"
      },
      {
        "command": "korgkode.healTests",
        "title": "KorgKode: Run TDD Healer on Current File"
      },
      {
        "command": "korgkode.profileTests",
        "title": "KorgKode: Profile Test Suite"
      },
      {
        "command": "korgkode.openDashboard",
        "title": "KorgKode: Open the Swarm Dashboard"
      }
    ],
    "configuration": {
      "title": "KorgKode",
      "properties": {
        "korgkode.backendUrl": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "URL of the KorgKode FastAPI server"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.1.3"
  }
}